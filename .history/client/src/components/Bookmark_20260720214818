<script setup lang="ts">
import { computed } from 'vue'
import { useSettingsStore } from '@/stores/settingsStore'
import type { Bookmark } from '@/types'

const props = defineProps<{ bookmark: Bookmark }>()
const settingsStore = useSettingsStore()

const cardStyle = computed(() => ({
  width: `${settingsStore.iconSize}px`,
  height: `${settingsStore.iconSize}px`,
}))

const defaultIcon = 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23e2e8f0"/><text x="50" y="65" font-size="40" text-anchor="middle" fill="%2394a3b8">★</text></svg>'

function onIconError(event: Event) {
  const img = event.target as HTMLImageElement
  img.src = defaultIcon
}

function openLink() {
  window.open(props.bookmark.url, '_blank')
}
</script>

<template>
  <div class="bookmark-card" :style="cardStyle" @click="openLink">
    <img 
      class="bookmark-icon"
      :src="bookmark.faviconUrl || defaultIcon"
      :alt="bookmark.name"
      @error="onIconError"
      loading="lazy"
    />
    <div class="bookmark-name" :title="bookmark.name">{{ bookmark.name }}</div>
  </div>
</template>

<style scoped>
.bookmark-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  text-decoration: none;
  color: var(--text);
  transition: transform 0.2s, box-shadow 0.2s;
  padding: 12px;
  border-radius: 12px;
}

.bookmark-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
  background: var(--accent-bg);
}

.bookmark-icon {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  object-fit: cover;
  background: var(--code-bg);
}

.bookmark-name {
  font-size: 13px;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 4px;
  color: var(--text-h);
}

@media (max-width: 768px) {
  .bookmark-icon {
    width: 40px;
    height: 40px;
  }
  .bookmark-name {
    font-size: 12px;
  }
}

@media (max-width: 480px) {
  .bookmark-card {
    padding: 8px;
  }
  .bookmark-icon {
    width: 32px;
    height: 32px;
  }
}
</style>